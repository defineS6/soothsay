  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.0.15",
    "vue-tsc": "^3.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": []
